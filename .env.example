# ─────────────────────────────────────────────────────────────
# Payroll Management System — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env`. See src/lib/env.ts for runtime validation.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local docker-compose default matches these credentials.
DATABASE_URL="postgresql://payroll:payroll@localhost:5432/payroll?schema=public"

# Auth.js / NextAuth secret. Generate with: `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-a-32-byte-random-string"

# Public base URL of the app (used by Auth.js callbacks).
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Company identity shown on payslips and reports.
COMPANY_NAME="Northwind Consulting d.o.o."
COMPANY_ADDRESS="Bulevar Oslobođenja 1, 11000 Beograd, Serbia"
COMPANY_TAX_ID="RS-100200300"

# Node environment (development | production | test)
NODE_ENV="development"
